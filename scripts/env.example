# /etc/ccclaw/env — ccclaw 环境变量配置
# 复制此文件到 /etc/ccclaw/env 并填写实际值
# 权限: chmod 600 /etc/ccclaw/env

# GitHub PAT（最小权限：issues:read + issues:write）
CCCLAW_GH_TOKEN=ghp_your_token_here

# 目标仓库
CCCLAW_REPO=NOTAschool/sys4NOTA

# claude 可执行文件路径
CCCLAW_CLAUDE_BIN=claude

# 状态文件目录
CCCLAW_STATE_DIR=/var/lib/ccclaw

# 日志目录
CCCLAW_LOG_DIR=/var/log/ccclaw

# 触发 ingest 的 Issue 标签（留空则拉取所有开放 Issue）
CCCLAW_INGEST_LABEL=ccclaw

# 每次最多拉取的 Issue 数量
CCCLAW_INGEST_LIMIT=20

# 任务工作区目录（每个任务独立子目录）
CCCLAW_WORKSPACE_DIR=/var/lib/ccclaw/workspace

# 仓库根目录（用于定位 docs/ 和 skills/）
CCCLAW_REPO_ROOT=/opt/src/ccclaw

# docs/ 记忆目录（默认 $CCCLAW_REPO_ROOT/docs）
# CCCLAW_DOCS_DIR=/opt/src/ccclaw/docs

# skills/ 目录（默认 $CCCLAW_REPO_ROOT/skills）
# CCCLAW_SKILLS_DIR=/opt/src/ccclaw/skills
